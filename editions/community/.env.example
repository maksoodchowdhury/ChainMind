OPENAI_API_KEY=your_openai_api_key_here
APP_NAME=ChainMind Community
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=supply_chain_documents
LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGGING=true
AUTHZ_ENABLED=false
TENANT_QUOTA_ENABLED=false
AUTONOMY_AUTO_EXECUTE_ENABLED=false

# Basic in-memory rate limiting (recommended for API hardening)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_WINDOW=60
RATE_LIMIT_WINDOW_SECONDS=60

# Ingestion queue backpressure (pending + processing jobs)
MAX_INFLIGHT_INGESTION_JOBS=50

# SLO thresholds for /metrics/slo-status
SLO_ERROR_RATE_THRESHOLD=0.01
SLO_P95_LATENCY_MS_THRESHOLD=800
SLO_MINIMUM_REQUESTS=20
SLO_WEBHOOK_URL=
SLO_WEBHOOK_SECRET=
SLO_ALERT_COOLDOWN_SECONDS=300
SLO_WEBHOOK_MAX_ATTEMPTS=3
SLO_WEBHOOK_BACKOFF_SECONDS=1

# Optional features (false by default; require additional pip installs)
# See requirements.txt for the packages to uncomment
ENABLE_HYBRID_SEARCH=false
ENABLE_RERANKING=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=3

# Chunking strategy: sentence | semantic | fixed (default: sentence)
CHUNKING_STRATEGY=sentence
CHUNK_SIZE=1024
CHUNK_OVERLAP=256

# Redis query caching (optional — install: pip install redis)
# Leave blank to disable caching
REDIS_URL=
CACHE_TTL_SECONDS=3600

# API key authentication (optional)
# AUTH_ENABLED=false means all endpoints are public
AUTH_ENABLED=false
# Comma-separated list of valid API keys
API_KEYS=

# OpenTelemetry tracing (optional — install: pip install opentelemetry-api opentelemetry-sdk)
ENABLE_TRACING=false
OTLP_ENDPOINT=http://localhost:4317
